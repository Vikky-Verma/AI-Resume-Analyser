// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Analysis {
  id              String   @id @default(cuid())
  resumeId        String   @unique
  score           Float
  atsScore        Float
  domain          String?
  experienceLevel String?
  skills          String[]
  missingSkills   String[]
  suggestions     String[]
  resume          Resume   @relation(fields: [resumeId], references: [id])
}

model Resume {
  id             String   @id @default(cuid())

  originalName   String
  filePath       String

  extractedText  String?

  uploadedAt     DateTime @default(now())

  userId         String
  user           User @relation(fields: [userId], references: [id])

  analysis       Analysis?
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  
  resume    Resume[]
  mockInterviews MockInterview[]
  companyProgress CompanyPrepProgress[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyPrepProgress {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  company     String   // company slug, e.g. "google"

  // question ids (e.g. "google-1") the user has marked as solved
  solvedIds   String[]

  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([userId, company])
}

model MockInterview {
  id              String    @id @default(cuid())

  userId          String
  user            User      @relation(fields: [userId], references: [id])

  resumeId        String?

  company         String
  role            String
  level           String    // Fresher | Intermediate | Advanced

  status          String    @default("in_progress") // in_progress | completed

  // Array of { type, label, score, questions: [{ question, answer, score, feedback }] }
  rounds          Json

  overallScore    Float?
  overallFeedback String?
  verdict         String?

  createdAt       DateTime  @default(now())
  completedAt     DateTime?
}